  <capabilities>
    <dimmer>True</dimmer>
    <on_off>True</on_off>
    <has_load>True</has_load>
    <set_level>True</set_level>
    <supports_target>True</supports_target>
  </capabilities>
  <config>
    <script jit="1" file="driver.lua"/>
    <properties>
      <property>
        <name>Driver Version</name>
        <type>STRING</type>
        <readonly>true</readonly>
        <default>1.0.0</default>
      </property>
      <property>
        <name>Accessory AID</name>
        <type>STRING</type>
        <default>1</default>
        <tooltip>Accessory ID (aid) on the paired HomeKit accessory this light represents.</tooltip>
      </property>
      <property>
        <name>Debug Mode</name>
        <type>LIST</type>
        <items>
          <item>Off</item>
          <item>On</item>
        </items>
        <default>Off</default>
      </property>
    </properties>
    <actions />
    <commands />
  </config>
  <connections>
    <connection>
      <id>5001</id>
      <facing>6</facing>
      <connectionname>Light</connectionname>
      <type>2</type>
      <consumer>False</consumer>
      <classes>
        <class>
          <classname>LIGHT_V2</classname>
        </class>
      </classes>
    </connection>
    <connection>
      <id>999</id>
      <facing>1</facing>
      <type>1</type>
      <connectionname>HomeKit Hub</connectionname>
      <consumer>True</consumer>
      <classes>
        <class>
          <classname>HOMEKIT_DEVICE</classname>
          <autobind>True</autobind>
        </class>
      </classes>
    </connection>
  </connections>
